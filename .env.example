# Jotform
JOTFORM_API_KEY=
JOTFORM_FORM_ID=222484018864157
JOTFORM_BASE_URL=https://api.jotform.com

# Encompass (sandbox)
ENCOMPASS_BASE_URL=https://api.elliemae.com
ENCOMPASS_INSTANCE_ID=TEBE11221740
ENCOMPASS_CLIENT_ID=
ENCOMPASS_CLIENT_SECRET=
# OAuth grant: "client_credentials" (recommended, when the client is bound
# to an API User in Admin Tools) or "password" (requires admin creds below).
ENCOMPASS_GRANT_TYPE=client_credentials
# Only required if ENCOMPASS_GRANT_TYPE=password. Leave blank otherwise.
ENCOMPASS_ADMIN_USER=
ENCOMPASS_ADMIN_PASSWORD=

# Org the new hires are placed in. If ENCOMPASS_NEW_HIRES_ORG_ID is set
# the list-orgs API call is skipped (useful when the client lacks admin
# list permission). Otherwise the service looks the org up by name.
ENCOMPASS_NEW_HIRES_ORG_NAME=New Hires
ENCOMPASS_NEW_HIRES_ORG_ID=

# Default domain used to synthesize the work email
EMAIL_DOMAIN=mortgageright.com

# Polling
POLL_INTERVAL_SECONDS=300
STATE_DB_PATH=./state.sqlite3

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/service.log
